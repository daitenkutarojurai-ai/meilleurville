# MeilleurVille — env vars
# Copy to .env.local for local dev. In production set non-secret vars under
# [vars] in wrangler.toml and secrets via `wrangler secret put` (Cloudflare).
# Public variables are inlined into the client bundle at build time.

# ───── Locale / domain ─────────────────────────────────────────────────────
# Which locale this deployment serves. "fr" (default) or "en".
# Drives the Worker locale isolation, sitemap output, hreflang defaults.
NEXT_PUBLIC_DEFAULT_LOCALE=fr

# Canonical origin of THIS deployment. Used for canonical URLs, OG cards,
# JSON-LD, sitemap. Set to the production domain (no trailing slash).
NEXT_PUBLIC_BASE_URL=https://www.mavilleideale.fr

# Cross-domain bilingual hreflang pair. Both projects know about both URLs.
NEXT_PUBLIC_BASE_URL_FR=https://www.mavilleideale.fr
NEXT_PUBLIC_BASE_URL_EN=https://bestcitiesinfrance.com

# ───── Newsletter (Brevo) ──────────────────────────────────────────────────
# Brevo REST v3 API key — must start with `xkeysib-` (NOT an SMTP key).
# Without it, the newsletter route degrades gracefully (no send).
BREVO_API_KEY=xkeysib-...

# Brevo list IDs per locale. Set only the lists this project should send to.
# FR list = 4, EN list = 5 in the current Brevo workspace.
BREVO_LIST_ID_FR=4
BREVO_LIST_ID_EN=5

# Sender addresses shown in the newsletter. Defaults are baked in but
# override here if you change the From: identity.
NEWSLETTER_FROM_EMAIL_FR=lettre@mavilleideale.fr
NEWSLETTER_FROM_EMAIL_EN=newsletter@bestcitiesinfrance.com

# (Note: the previous Vercel HTTP-cron model used CRON_SECRET; Cloudflare cron
# triggers fire scheduled() directly inside the Worker — no shared secret.)

# ───── Contact form ────────────────────────────────────────────────────────
# Inbox that receives form submissions and the From: address used to send
# them (Brevo requires a verified sender).
CONTACT_TO_EMAIL=contact@mavilleideale.fr
CONTACT_FROM_EMAIL=noreply@mavilleideale.fr
# Per-locale override (optional — falls back to CONTACT_FROM_EMAIL).
CONTACT_FROM_EMAIL_FR=noreply@mavilleideale.fr
CONTACT_FROM_EMAIL_EN=noreply@bestcitiesinfrance.com

# ───── Booking.com affiliate (vacances vertical) ───────────────────────────
# Without this var the links still work but lose attribution.
NEXT_PUBLIC_BOOKING_AID=

# ───── Auth (Worker-native magic link — R9.1) ──────────────────────────────
# Accounts are passwordless: a one-time link is emailed (via Brevo), then traded
# for a session JWT signed with this secret. Set it as a WORKER SECRET, not here:
#   wrangler secret put AUTH_SECRET
# Use a long random value (e.g. `openssl rand -base64 48`). Without it the
# /api/auth/* endpoints refuse to run (503). No Supabase/Clerk dependency.
AUTH_SECRET=change-me-to-a-long-random-string

# ───── Anthropic (copilot — R11) ──────────────────────────────────────────
# Required for /copilot. Without it the route returns a graceful fallback.
ANTHROPIC_API_KEY=sk-ant-...

# ───── Social media (scripts/social-post.mjs) ────────────────────────────
# Only needed for the social-posting scripts — not used at runtime.
FB_APP_ID=
FB_APP_SECRET=
FB_ACCESS_TOKEN=
FB_PAGE_ID=
FB_PAGE_TOKEN=
IG_USER_ID=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_URN=
LINKEDIN_TOKEN_EXPIRES=
