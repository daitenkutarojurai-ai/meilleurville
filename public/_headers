# Cloudflare Workers Static Assets headers.

# Content-hashed Next bundles never change — skip the default
# max-age=0,must-revalidate round-trips.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# City photos carry a content hash in the filename (scripts/commune-images.mjs),
# so a changed photo ships under a new URL — the old one can be cached forever.
/photos/*
  Cache-Control: public, max-age=31536000, immutable

# Next's opengraph-image routes export as extensionless files (e.g.
# out/about/opengraph-image), which CF would otherwise serve as
# application/octet-stream. Force image/png so social scrapers render them.
/opengraph-image
  Content-Type: image/png
  Cache-Control: public, max-age=86400
/*/opengraph-image
  Content-Type: image/png
  Cache-Control: public, max-age=86400

# HTML + everything else: baseline security headers.
#
# No Cache-Control here on purpose. Cloudflare MERGES every matching rule, so a
# Cache-Control on /* was appended to the ones above —
# `max-age=31536000, immutable, public, max-age=0, must-revalidate` — and
# browsers honour the FIRST max-age, so the hashed bundles were never actually
# cached. Dropping it lets the specific rules stand alone; HTML still gets
# `public, max-age=0, must-revalidate`, which is the Workers Assets default.
#
# /widget/embed is served by the Worker (sends its own frame-ancestors *) and is
# unaffected by asset-level headers.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  X-Frame-Options: SAMEORIGIN
